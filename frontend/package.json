{
  "name": "cognitivesense-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform Electron boilerplate for an ambient coaching shell.",
  "main": "dist-electron/electron/main.js",
  "type": "commonjs",
  "desktopName": "cognitivesense-shell.desktop",
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:renderer": "vite --strictPort",
    "dev:desktop": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:electron": "concurrently -k \"tsc -p tsconfig.node.json --watch\" \"wait-on tcp:5173 dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electronmon .\"",
    "build": "npm run build:renderer && npm run build:desktop",
    "build:renderer": "vite build",
    "build:desktop": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.genesis.cognitivesense",
    "productName": "CognitiveSense",
    "files": [
      "assets/**",
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "electron": "28.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^26.0.12",
    "electronmon": "^2.0.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
